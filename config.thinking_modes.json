{
  "_comment": "思考模式对比测试配置 - 对比不同推理等级的性能差异",
  "_usage": "适用于测试思考推理模型的不同推理等级（off/low/medium/high）性能表现",
  "_purpose": "验证思考模式对性能的影响，确定最佳推理等级配置",
  "_instructions": "使用前请替换：YOUR_BASE_URL、YOUR_API_KEY、YOUR_CHAT_MODEL、YOUR_RESPONSES_MODEL",

  "base_url": "YOUR_BASE_URL",
  "api_key": "YOUR_API_KEY",
  "chat_model": "YOUR_CHAT_MODEL",
  "responses_model": "YOUR_RESPONSES_MODEL",
  "embedding_model": "YOUR_EMBEDDING_MODEL",

  "responses_reasoning_effort": "medium",
  "responses_text_verbosity": "low",

  "log_dir": "logs",
  "report_dir": "reports",
  "request_timeout_seconds": 180,
  "wait_time_min": 1,
  "wait_time_max": 3,

  "paths": {
    "chat_completions": "/v1/chat/completions",
    "responses": "/v1/responses",
    "embeddings": "/v1/embeddings"
  },

  "traffic_ratio": {
    "_comment": "思考模式测试：4个等级等权重，确保各等级有足够的测试数据",
    "_note": "同时保留基础接口用于对比",
    "chat_stream": 2,
    "chat_non_stream": 1,
    "responses_thinking_off": 1,
    "responses_thinking_low": 1,
    "responses_thinking_medium": 1,
    "responses_thinking_high": 1
  },

  "thinking_mode_config": {
    "enabled": true,
    "description": "思考模式测试配置。启用不同推理等级的独立测试场景",
    "scenarios": {
      "off": {"reasoning_effort": null, "weight": 1, "description": "禁用思考模式，用于对比基准"},
      "low": {"reasoning_effort": "low", "weight": 1, "description": "轻度思考，适合简单推理任务"},
      "medium": {"reasoning_effort": "medium", "weight": 1, "description": "中度思考，适合复杂推理任务"},
      "high": {"reasoning_effort": "high", "weight": 1, "description": "深度思考，适合高度复杂推理任务"}
    }
  },

  "context_scenarios": {
    "enabled": false,
    "description": "上下文场景配置。思考模式对比测试不启用"
  }
}
